# --- 区块链节点连接 (从 Alchemy 或 Infura 获取) ---
# 建议使用 Sepolia 测试网，以免消耗真实资金
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# --- 钱包私钥 (用于部署合约) ---
# 注意：在真实的 .env 文件中，私钥必须以 0x 开头
# 强烈建议使用没有任何真实资产的“丢弃型”测试钱包
PRIVATE_KEY=0x_YOUR_TESTNET_PRIVATE_KEY_HERE

# --- 合约验证 (从 Etherscan 获取) ---
# 用于在区块链浏览器上公开你的源代码，增加项目可信度
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# --- 前端配置 (可选) ---
# 如果你的前端需要连接特定的 WalletConnect 项目 ID
NEXT_PUBLIC_PROJECT_ID=YOUR_WALLET_CONNECT_PROJECT_ID